# Windows Authentication (recommended for local SQL Server)
DB_SERVER=localhost
DB_NAME=AC073_VANUR
DB_DRIVER=ODBC Driver 17 for SQL Server
USE_WINDOWS_AUTH=true

# SQL Server Authentication (set USE_WINDOWS_AUTH=false)
# DB_USER=sa
# DB_PASSWORD=YourPassword123

# Production server (run_production.py)
# HOST=0.0.0.0
# PORT=8080
